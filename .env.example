# Copia este fichero a .env y rellena los valores

# Token del bot de Telegram (obtenlo de @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Tu chat ID personal de Telegram (obtenlo de @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here

# URL de PostgreSQL (Railway te la da automaticamente como envvar DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname
